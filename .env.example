APP_NAME="Mealie MCP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mealie-mcp.yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# This app does not use a database — set everything to file-based
DB_CONNECTION=sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MAIL_MAILER=log

# Mealie instance URL (no trailing slash)
# Example: https://mealie.yourdomain.com
MEALIE_BASE_URL=

# Troubleshooting: when true, every Mealie API request and response is logged
# to storage/logs/laravel.log. Failed requests (e.g. 422 validation errors) are
# always logged with their full response body. To see the verbose request/response
# lines as well, also set LOG_LEVEL=debug above. Leave off in normal production.
MEALIE_DEBUG=false
